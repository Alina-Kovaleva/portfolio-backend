{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022", "DOM"],
    "jsx": "react-jsx",
    "baseUrl": ".",
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true
  },
  "include": [
    "./sanity.config.ts",
    "./schemas/**/*.ts",
    "./schemas/**/*.tsx",
    "./schemas/**/*.js",
    "./schemas/**/*.jsx"
  ]
}
